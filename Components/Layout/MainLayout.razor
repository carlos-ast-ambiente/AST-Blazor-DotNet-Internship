@inherits LayoutComponentBase

<MudThemeProvider Theme="@_theme"/>
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Fixed="true" Color="Color.Primary" Elevation="2">
        <MudIconButton Icon="@Icons.Material.Filled.Dehaze" OnClick="@ToggleDrawer" />
        <MudText Typo="Typo.h4">BlazorApp</MudText>
        <MudSpacer />
        <MudIconButton Icon="@Icons.Material.Filled.AccountCircle" Href="/profile"/>
    </MudAppBar>

    <NavMenu SideBarOpen="@_drawerOpen" />

    <MudMainContent MaxWidth="MaxWidth.Large" Class="pa-4">
        @Body
    </MudMainContent>
</MudLayout>

@code
{
    private MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = "#596746",
            Secondary = "#809568",
            Background = "#616161",
            Surface = "#424242",
            TextPrimary = "#A3AE97",
            TextSecondary = "#909B84"
        }

    };

    private bool _drawerOpen = true;

    void ToggleDrawer() {
        _drawerOpen = !_drawerOpen;
    }
}
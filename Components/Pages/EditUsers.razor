@page "/admin/users/{Id:int}/editUsers"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using BlazorApp.Models
@using BlazorApp.Services
@attribute [Authorize(Roles = "Admin")]
@inject UserManager<User> UserManager
@inject RoleManager<IdentityRole<int>> RoleManager
@inject IJSRuntime JSRuntime
@inject NavigationManager NavigationManager
@inject BlazorApp.Services.UserService UserService

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-16">
    <MudPaper Elevation="6" Class="pa-8">
        <MudText Typo="Typo.h4" Class="mb-4">Users Management</MudText>

        @if (!string.IsNullOrWhiteSpace(_message)) {
            <MudAlert Severity="@_messageSeverity" Class="mb-4" ShowCloseIcon="true" CloseIconClicked="(() => _message = null)">@_message</MudAlert>
        }

        @if (user == null)
        {
            <MudProgressCircular Indeterminate="true" />
        }
        else
        {
            <MudPaper Elevation="4" Class="pa-8">
                <EditForm Model="user" OnValidSubmit="SaveUserAsync">
                    <DataAnnotationsValidator />

                    <MudGrid>

                        <MudItem xs="12" md="6">
                            <MudText Typo="Typo.h6">Name</MudText>
                            <MudTextField @bind-Value="user.Name" />
                        </MudItem>

                        <MudItem xs="12" md="6">
                            <MudText Typo="Typo.h6">Username</MudText>
                            <MudTextField @bind-Value="user.UserName" />
                        </MudItem>

                        <MudItem xs="12" md="6">
                            <MudText Typo="Typo.h6">Email</MudText>
                            <MudTextField @bind-Value="user.Email" />
                        </MudItem>

                        <MudItem xs="12" md="6">
                            <MudText Typo="Typo.h6">Role</MudText>

                            <MudSelect T="string" @bind-Value="_selectedRole">
                                @foreach (var role in _allRoles)
                                {
                                    <MudSelectItem Value="@role">@role</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>

                    </MudGrid>

                    <MudStack Row="true" Spacing="6" Class="mt-8 w-100">
                        <MudButton ButtonType="ButtonType.Submit"
                                Variant="Variant.Filled"
                                Color="Color.Primary"
                                Class="mt-8 rounded-pill">
                            Save
                        </MudButton>

                        <MudButton Variant="Variant.Filled" Coor="Color.Background" @onclick='() => NavigationManager.NavigateTo("/admin/users")' Class="mt-8 rounded-pill">
                            Cancel
                        </MudButton>

                        <MudSpacer />

                        <MudButton Variant="Variant.Filled"
                                Color="Color.Error"
                                OnClick="@(() => ConfirmDeleteAsync(user))"
                                Class="mt-8 rounded-pill">
                            Delete
                        </MudButton>
                    </MudStack>
                </EditForm>
            </MudPaper>
        }
    </MudPaper>
</MudContainer>


@code {
    [Parameter]
    public int Id { get; set; }
    private User? user;
    private string? _selectedRole;
    private List<string> _allRoles = [];
    private string? _message;
    private Severity _messageSeverity = Severity.Info;

    protected override async Task OnInitializedAsync() {
        user = await UserService.GetUserAsync(Id);

        if (user == null)
            return;

        _allRoles = await UserService.GetAllRolesAsync();

        _selectedRole = await UserService.GetUserRoleAsync(user);
    }

    private async Task SaveUserAsync() {
        if (user == null) {
            return;
        }

        if (string.IsNullOrEmpty(_selectedRole))
        {
            _messageSeverity = Severity.Error;
            _message = "Please select a role.";
            return;
        }

        var result = await UserService.UpdateUserAsync(user, _selectedRole);

        if(!result.Succeeded) {
            _messageSeverity = Severity.Error;
            _message = string.Join(", ", result.Errors.Select(e => e.Description));
            return;
        }

        _messageSeverity = Severity.Success;
        _message = $"{user.UserName} updated successfully";

        NavigationManager.NavigateTo("/admin/users");
    }

    private async Task ConfirmDeleteAsync(User user) {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", $"Delete {user.UserName}?");

        if (!confirmed) {
            return;
        }

        var result = await UserService.DeleteUserAsync(user);

        if (result.Succeeded) {
            _messageSeverity = Severity.Success;
            _message = $"Deleted {user.UserName}.";
            NavigationManager.NavigateTo("/admin/users");
        }
        else {
            _messageSeverity = Severity.Error;
            _message = string.Join(", ", result.Errors.Select(e => e.Description));
        }
    }
}
